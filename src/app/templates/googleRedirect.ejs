<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connecting to CineTube...</title>
    <style>
      :root {
        --primary-red: #E50914; 
        --bg-color: #141414; 
        --text-main: #FFFFFF;
        --text-muted: #B3B3B3;
      }

      body {
        margin: 0;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background-color: var(--bg-color);
        background-image: radial-gradient(circle at center, #232323 0%, #141414 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        color: var(--text-main);
        overflow: hidden;
      }

      .cinetube-container {
        text-align: center;
        max-width: 400px;
        width: 90%;
        padding: 40px;
        animation: cinematicFadeIn 1s ease-out forwards;
        opacity: 0;
        transform: scale(0.95);
      }

      .brand-logo {
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: 2px;
        color: var(--primary-red);
        margin-bottom: 40px;
        text-transform: uppercase;
        text-shadow: 0 0 10px rgba(229, 9, 20, 0.4);
      }

      .status-title {
        font-size: 1.4rem;
        font-weight: 500;
        margin: 0 0 12px 0;
        letter-spacing: 0.5px;
      }

      .status-subtitle {
        font-size: 1rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.5;
      }

      .loader-container {
        height: 70px;
        margin: 0 auto 30px auto;
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .streaming-spinner {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        border: 4px solid rgba(229, 9, 20, 0.2);
        border-top-color: var(--primary-red);
        animation: spin 1s cubic-bezier(0.5, 0.1, 0.4, 0.9) infinite;
      }

      .error-icon-svg {
        display: none; 
        width: 60px;
        height: 60px;
        margin: 0 auto 30px auto;
        color: var(--primary-red);
      }

      .is-error .loader-container { display: none; }
      .is-error .error-icon-svg { display: block; }

      @keyframes cinematicFadeIn {
        to { opacity: 1; transform: scale(1); }
      }

      @keyframes spin {
        100% { transform: rotate(360deg); }
      }
    </style>
  </head>
  <body>
    <div class="cinetube-container" id="redirect-card">
      <div class="brand-logo">CineTube</div>
      <div class="loader-container">
        <div class="streaming-spinner"></div>
      </div>

      <svg class="error-icon-svg" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>

      <h1 class="status-title" id="main-status-text">Authenticating...</h1>
      <p class="status-subtitle" id="sub-status-text">Connecting securely to your account via Google.</p>
    </div>

    <script>
      const cardContainer = document.getElementById('redirect-card');
      const mainText = document.getElementById('main-status-text');
      const subText = document.getElementById('sub-status-text');

      function handleError(errorMessage) {
        cardContainer.classList.add('is-error');
        mainText.textContent = "Connection Failed";
        subText.textContent = errorMessage;
      }

      (async () => {
        try {
          const response = await fetch(
            // 🚨 UPDATED PATH: Ensure this matches your /api/v1/auth mount point
            `<%= betterAuthUrl %>/api/v1/auth/sign-in/social`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({
                provider: "google",
                callbackURL: `<%= callbackURL %>`,
              }),
            }
          );

          let data;
          try {
             data = await response.json();
          } catch(e) {
             throw new Error("Server communication error.");
          }
          
          if (response.ok && data.url) {
            mainText.textContent = "Setting up your profile...";
            subText.textContent = "Redirecting you to Google.";
            
            setTimeout(() => {
                window.location.href = data.url;
            }, 450);
            
          } else {
            handleError(data?.message || "Google login is currently unavailable.");
          }
        } catch (err) {
          handleError(`Connection issue: ${err.message}`);
        }
      })();
    </script>
  </body>
</html>