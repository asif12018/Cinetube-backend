// =============================================================
// BASE - Configuration and Enums
// =============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum MediaType {
  MOVIE
  SERIES
}

enum MediaStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  UNPUBLISHED
}

enum PricingTier {
  FREE
  PREMIUM
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum PurchaseType {
  SUBSCRIPTION
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
