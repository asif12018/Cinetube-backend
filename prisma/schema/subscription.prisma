// =============================================================
// PURCHASES & RENTALS (PAY-PER-VIEW)
// =============================================================

model Purchase {
  id              String        @id @default(uuid(7))
  userId          String
  
  // 1. Link the purchase directly to the Movie/Series they are buying
  mediaId         String       
  
  // 2. This will be either "RENTAL" or "ONE_TIME_BUY"
  type            PurchaseType  
  
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  
  // 3. If they rent it, this stores when their 48-hour access expires
  accessTimeStartedAt DateTime?
  accessExpiresAt DateTime?     

  paymentStatus   PaymentStatus @default(PENDING)
  paymentProvider String?       // "stripe" | "sslcommerz"
  providerTxnId   String?       @unique
  providerPayload Json?         // raw webhook payload for audit
  refundedAt      DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mediaId])
  @@index([paymentStatus])
  @@map("purchase")
}

model Subscription {
  id                 String        @id @default(uuid(7))
  userId             String        @unique 
  status             SubscriptionStatus @default(PENDING) // ACTIVE, PAST_DUE, CANCELED
  
  // 🟢 The exact billing cycle dates (Updated by Stripe/Webhook every month)
  currentPeriodStart DateTime      
  currentPeriodEnd   DateTime      
  
  // 🟢 Pro-tip: If they cancel, they still get to watch until the 'End' date
  cancelAtPeriodEnd  Boolean       @default(false)

  // Tracking details
  paymentProvider    String?       // "stripe", "sslcommerz"
  providerSubId      String?       @unique 
  stripeCustomerId   String?
  
  createdAt          DateTime      @default(now()) // When they first subscribed ever
  updatedAt          DateTime      @updatedAt

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription")
}
